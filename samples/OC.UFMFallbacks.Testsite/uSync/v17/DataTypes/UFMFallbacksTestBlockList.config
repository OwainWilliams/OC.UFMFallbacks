<?xml version="1.0" encoding="utf-8"?>
<DataType Key="2b45c7f7-ce10-41bf-8c74-84b655dd4eba" Alias="UFM Fallbacks Test Block List" Level="1">
  <Info>
    <Name>UFM Fallbacks Test Block List</Name>
    <EditorAlias>Umbraco.BlockList</EditorAlias>
    <EditorUIAlias>Umb.PropertyEditorUi.BlockList</EditorUIAlias>
  </Info>
  <Config><![CDATA[{
  "blocks": [
    {
      "contentElementTypeKey": "9818a435-e552-4102-96c6-a65447fddfb3",
      "label": "{fbk: title || subtitle} - {fbk: richContent | striphtml | truncate:60}",
      "backgroundColor": "#e8f5e9",
      "iconColor": "#2e7d32"
    },
    {
      "contentElementTypeKey": "da89569d-01e4-4df0-b841-8c6835d778d0",
      "label": "{fbk: galleryTitle} ({fbk: images | count:image,images})",
      "backgroundColor": "#e3f2fd",
      "iconColor": "#1565c0"
    },
    {
      "contentElementTypeKey": "ef161f1f-be82-4ac0-90e0-2c4877e545f4",
      "label": "{fbk: heading | uppercase} - {fbk: body | wordlimit:10}",
      "backgroundColor": "#fff3e0",
      "iconColor": "#e65100"
    },
    {
      "contentElementTypeKey": "6eb3e6c3-167c-443d-a7fa-4da992f46dbc",
      "label": "{fbk: ctaText || description || fallbackText | truncate:40}",
      "backgroundColor": "#fce4ec",
      "iconColor": "#c62828"
    }
  ],
  "useInlineEditingAsDefault": false,
  "useLiveEditing": true
}]]></Config>
</DataType>